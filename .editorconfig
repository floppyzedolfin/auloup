root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
# intellij_idea keeps ktlint close to Android Studio's default formatting,
# avoiding the very opinionated wrapping of the ktlint_official style.
ktlint_code_style = intellij_idea
max_line_length = 120
# @Composable functions are intentionally PascalCase.
ktlint_standard_function-naming = disabled

[*.{yml,yaml,xml,toml}]
indent_size = 2
