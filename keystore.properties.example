# Copy this file to "keystore.properties" (which is gitignored) and fill it in
# to sign the release build for the Play Store. See RELEASE.md for how to create
# the keystore. NEVER commit keystore.properties or the .jks file.

# Path to your upload keystore, relative to the repo root (or absolute).
storeFile=upload-keystore.jks

# Passwords and key alias you chose when running keytool.
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
