<?xml version="1.0" encoding="utf-8"?>
<!-- In-app logo: Iris, the sleepy wolf, on her night-blue circle. Lean, tapered
     wolf face with pointed ears and a pale heart-shaped muzzle. The face is
     scaled up inside the circle so her eyes read clearly; the eyes-open overlay
     (ic_logo_eyes_open) uses the same group transform. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:fillColor="#2C3E50"
        android:pathData="M54,0 A54,54 0 1,0 54,108 A54,54 0 1,0 54,0 Z" />

    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="1.3"
        android:scaleY="1.3">
        <!-- Head and ears -->
        <path
            android:fillColor="#9FB1BD"
            android:pathData="M29,32 L48,46 L54,42 L60,46 L79,32 L74,59 C73,72 65,80 54,80 C43,80 35,72 34,59 Z" />
        <path android:fillColor="#5D6D7E" android:pathData="M35,37 L46,47 L40,47 Z" />
        <path android:fillColor="#5D6D7E" android:pathData="M73,37 L62,47 L68,47 Z" />
        <!-- Pale heart-shaped muzzle -->
        <path
            android:fillColor="#ECEFF1"
            android:pathData="M54,78 C44,71 43,62 49,60 C51,59 53,60 54,62 C55,60 57,59 59,60 C65,62 64,71 54,78 Z" />
        <!-- Nose -->
        <path android:fillColor="#2C3E50" android:pathData="M51,64 L57,64 L54,69 Z" />
        <!-- Sleepy (closed) eyes -->
        <path
            android:strokeColor="#2C3E50"
            android:strokeWidth="2.6"
            android:strokeLineCap="round"
            android:pathData="M39,54 Q45,59 51,54" />
        <path
            android:strokeColor="#2C3E50"
            android:strokeWidth="2.6"
            android:strokeLineCap="round"
            android:pathData="M57,54 Q63,59 69,54" />
    </group>
    <!-- The sleepy "zzz" is animated in AppLogo (Compose), drifting up from the
         muzzle; it is intentionally not baked into this vector. -->
</vector>
